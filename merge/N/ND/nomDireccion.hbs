{{#define id="nomDireccion"}}
  {{#section id="base"}}
    {{field id="noEsMexico" type="expr" value="=pais!='MX'"}}
    {{field id="entidadNoAplica" type="expr" value="=entidadFederativa=='88'"}}
    {{field id="entidadValida" type="expr" value="=calc.isNotEmpty(entidadFederativa)&&!calc.in(entidadFederativa,['00','88','99'])"}}
    {{field id="siDesconoceCalle" type="expr" value="=desconoceCalle=='si'"}}
    {{field id="siNoDesconoceDelegacion" type="expr" value="=desconoceDelegacion=='no'"}}
    {{field id="tieneDelegacion" type="expr" value="=calc.isNotEmpty(delegacion)"}}
    {{field id="siNoDesconoceCodigoPostal" type="expr" value="=desconoceCodigoPostal=='no'"}}
    {{field id="direccionNoEspecificado" type="expr" value="=entidadFederativa=='00'||codigoLocalidad=='9999'"}}
    {{#field id="pais" clearFields="entidadFederativa,localidad,otraLocalidad,codigoPostal,colonia,delegacion,seleccionarDelegacion,ciudad,codigoDelegacion,codigoEstado"}}
      {{#onChange}}
        {{set entidadFederativa="=pais!='MX'?'88':null"}}
        {{set codigoPostal="=pais!='MX'?'00000':null"}}
        {{set codigoDelegacion="=pais!='MX'?'997':null"}}
        {{set codigoEstado="=pais!='MX'?'88':null"}}
        {{set codigoLocalidad="=pais!='MX'?'9997':null"}}
      {{/onChange}}
    {{/field}}
    {{#field id="entidadFederativa"}}
      {{#onChange clearFields="codigoEstado,desconoceDelegacion,delegacion,localidad,otraLocalidad,codigoLocalidad,desconoceCodigoPostal,codigoPostal,codigoEstado"}}
        {{set codigoPostal="=calc.in(entidadFederativa,['00','88'])?'00000':entidadFederativa=='99'?'99999':null"}}
        {{set codigoDelegacion="=calc.in(entidadFederativa,['00','88'])?'999':entidadFederativa=='99'?'998':null"}}
        {{set codigoLocalidad="=calc.in(entidadFederativa,['00','88'])?'9999':entidadFederativa=='99'?'9998':null"}}
        {{set codigoEstado="=entidadFederativa"}}
      {{/onChange}}
    {{/field}}
    {{#field id="desconoceDelegacion"}}
      {{#onChange clearFields="delegacion,codigoDelegacion,localidad,otraLocalidad,codigoLocalidad,desconoceCodigoPostal,codigoPostal"}}
        {{set codigoPostal="=desconoceDelegacion=='noEspecificado'?'00000':desconoceDelegacion=='seIgnora'?'99999':null"}}
        {{set codigoDelegacion="=desconoceDelegacion=='noEspecificado'?'999':desconoceDelegacion=='seIgnora'?'998':null"}}
        {{set codigoLocalidad="=desconoceDelegacion=='noEspecificado'?'9999':desconoceDelegacion=='seIgnora'?'9998':null"}}
      {{/onChange}}
    {{/field}}
    {{#field id="delegacion"}}
      {{#editor}}
        {{param estado="=@codigoEstado||entidadFederativa"}}
        {{#onChange refresh="true" clearFields="codigoDelegacion,localidad,otraLocalidad,codigoLocalidad,desconoceCodigoPostal,seleccionarCodigoPostal,codigoPostal"}}
          {{set codigoDelegacion="=c_municipio"}}
        {{/onChange}}
      {{/editor}}
    {{/field}}
    {{#field id="localidad"}}
      {{#editor}}
        {{param estado="=@codigoEstado||entidadFederativa"}}
        {{param municipio="=@codigoDelegacion"}}
        {{#onChange refresh="true" clearFields="otraLocalidad,codigoLocalidad"}}
          {{set codigoLocalidad="=c_localidad"}}
        {{/onChange}}
      {{/editor}}
    {{/field}}
    {{#field id="desconoceCodigoPostal"}}
      {{#onChange clearFields="seleccionarCodigoPostal,codigoPostal"}}
        {{set codigoPostal="=desconoceCodigoPostal=='noEspecificado'?'00000':desconoceCodigoPostal=='seIgnora'?'99999':null"}}
      {{/onChange}}
    {{/field}}
    {{#field id="seleccionarCodigoPostal"}}
      {{#editor}}
        {{param estado="=entidadFederativa"}}
        {{param municipio="=codigoDelegacion"}}
        {{param codigoPostal="=codigoPostal"}}
        {{#onChange clearFields="codigoPostal"}}
          {{set codigoPostal="=d_codigo"}}
        {{/onChange}}
      {{/editor}}
    {{/field}}
    {{#field id="desconoceCalle"}}
      {{#onChange condition="=desconoceCalle=='si'" clearFields="calle,numeroExterior,numeroInterior"}}
        {{set calle="SIN INFORMACIÓN"}}
      {{/onChange}}
    {{/field}}
    {{validator type="expr" notValidIf="=!noEsMexico&&entidadNoAplica" message="Entidad Federativa Inválida para MÉXICO"}}
    {{validator type="expr" notValidIf="=_mainDoc._type=='_user'&&calc.in(@desconoceDelegacion,['seIgnora','noEspecificado'])" message="Prestador Servicios no puede tener dirección desconocida"}}
  {{/section}}
{{/define}}
